{
  "name": "boggle",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "difficulty": "bunx tsx src/lib/scripts/boardDifficulty.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "netlify dev:exec drizzle-kit migrate",
    "db:studio": "netlify dev:exec drizzle-kit studio",
    "postbuild": "npx svelte-sitemap"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.0",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.5.2",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.54.0",
    "svelte-check": "^4.4.2",
    "svelte-sitemap": "^3.0.1",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@netlify/functions": "^5.1.5",
    "@netlify/neon": "^0.1.2",
    "@sveltejs/adapter-static": "^3.0.10",
    "@types/seedrandom": "^3.0.8",
    "crypto": "^1.0.1",
    "drizzle-orm": "^0.45.2",
    "js-confetti": "^0.13.1",
    "seedrandom": "^3.0.5",
    "svg2png-wasm-rs": "^0.1.2"
  }
}
